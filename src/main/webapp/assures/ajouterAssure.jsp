
body{
    font-family: Arial, sans-serif;
    background-color: #f4f6f9;
    margin: 40px;
}

h1{
    color: #2c3e50;
}

h2{
    color: #34495e;
    margin-top: 30px;
}

a{
    display: inline-block;
    padding: 8px 15px;
    margin: 5px 0;
    background-color: #3498db;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}

a:hover{
    background-color: #2980b9;
}



form{
    background: white;
    padding: 20px;
    width: 300px;
    border-radius: 5px;
    box-shadow: 0px 0px 5px rgba(0,0,0,0.1);
}

input{
    width: 100%;
    padding: 7px;
    margin-top: 5px;
    margin-bottom: 15px;
    border: 1px solid #ccc;
    border-radius: 4px;
}

button{
    padding: 8px 15px;
    background-color: #27ae60;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
}

button:hover{
    background-color: #1e8449;
}

table{
    width: 70%;
    border-collapse: collapse;
    background: white;
}

th{
    background-color: #34495e;
    color: white;
    padding: 10px;
}

td{
    padding: 10px;
    border: 1px solid #ddd;
}

tr:hover{
    background-color: #f2f2f2;
}
